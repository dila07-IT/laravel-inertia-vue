{
    "name": "dilansabah/laravel-inertia-vue",
    "description": "Laravel package to install Inertia.js with Vue 3 setup",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2|^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Dilansabah\\LaravelInertiaVue\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dilansabah\\LaravelInertiaVue\\InertiaVueServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
